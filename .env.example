# ===== General =====
NODE_ENV=development
PORT=3000
# مفتاح تشفير الجلسات - غيّره في الإنتاج
SESSION_SECRET=change-me-to-a-long-random-string

# ===== Database =====
# مسار قاعدة بيانات SQLite (يُنشأ تلقائيًا)
DB_PATH=./data/getprice.db

# ===== Price Collection / Adapters =====
# مصدر الأسعار الافتراضي لكل adapter:
#   seed    = استخدم بيانات Seed المحلية (افتراضي، آمن للتجربة بدون إنترنت)
#   scraper = فعّل الزحف الحقيقي (يحترم robots.txt ومعدلات منخفضة)
PRICE_SOURCE=seed
# الحد الأدنى للتأخير بين طلبات نفس المتجر بالميلي ثانية (احترام Rate Limit)
SCRAPE_MIN_DELAY_MS=4000
# User-Agent المستخدم في الزحف
SCRAPE_USER_AGENT=GetPriceBot/1.0 (+contact: admin@example.com)
# جدولة جمع الأسعار (cron). الافتراضي كل 30 دقيقة
POLL_CRON=*/30 * * * *
# جدولة فحص العروض التلقائي. الافتراضي كل ساعة
SCAN_CRON=15 * * * *
# شغّل الجمع مرة عند الإقلاع؟
RUN_ON_BOOT=false

# ===== Deal / Alert thresholds =====
# الحد الأدنى لنسبة الخصم الحقيقي لإطلاق تنبيه (٪)
ALERT_REAL_DISCOUNT_PCT=40
# الحد الأدنى لـ Deal Score لإطلاق تنبيه
ALERT_MIN_DEAL_SCORE=70

# ===== Notifications: Email (SMTP) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM="GetPrice Alerts <alerts@example.com>"
# بريد المشرف لتنبيهات فشل الـ adapters
ADMIN_EMAIL=admin@example.com

# ===== Notifications: Telegram =====
TELEGRAM_BOT_TOKEN=
# القناة/الشات الافتراضي للمشرف (اختياري)
TELEGRAM_ADMIN_CHAT_ID=

# ===== Notifications: Web Push (VAPID) =====
# ولّدها عبر: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
